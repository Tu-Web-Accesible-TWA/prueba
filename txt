image: node:22-alpine

variables:
  PROJECT_DIR: "nombre-de-tu-carpeta-angular"

# 🌟 Reordenamos las etapas: primero Build, luego las Verificaciones
stages:
  - build
  - verify

cache:
  key:
    files:
      - $PROJECT_DIR/package-lock.json
  paths:
    - $PROJECT_DIR/.npm/
    - $PROJECT_DIR/node_modules/

workflow:
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"

# 🌟 Esto se ejecuta antes de CADA trabajo: entra en la carpeta e instala/recupera dependencias
before_script:
  - cd $PROJECT_DIR
  - npm ci --cache .npm --prefer-offline

# --- ETAPA DE COMPILACIÓN (Ahora va primero) ---
build:app:
  stage: build
  script:
    - npm run build -- --configuration=production
  artifacts:
    name: "dist-angular-$CI_COMMIT_REF_SLUG"
    paths:
      - $PROJECT_DIR/dist/
    expire_in: 1 week

# --- ETAPA DE VERIFICACIÓN (Se ejecutan en paralelo después del build) ---
lint:code:
  stage: verify
  script:
    - npm run lint

lint:style:
  stage: verify
  script:
    - npm run lint:style

audit:dependencies:
  stage: verify
  script:
    - npm audit --audit-level=high
  allow_failure: falsew