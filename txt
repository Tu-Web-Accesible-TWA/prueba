# Usamos una imagen ligera de Node compatible con Angular 21
image: node:22-alpine

variables:
  # 🌟 CONFIGURA AQUÍ EL NOMBRE DE TU CARPETA:
  PROJECT_DIR: "nombre-de-tu-carpeta-angular"

stages:
  - install
  - verify
  - build

# La caché se define desde la raíz, por lo que incluimos la variable de la carpeta
cache:
  key:
    files:
      - $PROJECT_DIR/package-lock.json
  paths:
    - $PROJECT_DIR/.npm/
    - $PROJECT_DIR/node_modules/

# Este pipeline SOLO se ejecutará cuando se abra o actualice un Merge Request
workflow:
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"

# 🌟 TRUCO CLAVE: Mueve el entorno a la carpeta del proyecto ANTES de que empiece cada trabajo
before_script:
  - cd $PROJECT_DIR

# --- ETAPA DE INSTALACIÓN ---
install_dependencies:
  stage: install
  script:
    - npm ci --cache .npm --prefer-offline

# --- ETAPA DE VERIFICACIÓN (En paralelo) ---
lint:code:
  stage: verify
  script:
    - npm run lint
  dependencies:
    - install_dependencies

lint:style:
  stage: verify
  script:
    - npm run lint:style
  dependencies:
    - install_dependencies

audit:dependencies:
  stage: verify
  script:
    - npm audit --audit-level=high
  dependencies:
    - install_dependencies
  allow_failure: false

# --- ETAPA DE COMPILACIÓN ---
build:app:
  stage: build
  script:
    - npm run build -- --configuration=production
  dependencies:
    - install_dependencies
  artifacts:
    name: "dist-angular-$CI_COMMIT_REF_SLUG"
    # Los artefactos se buscan desde la raíz del repositorio al terminar el script
    paths:
      - $PROJECT_DIR/dist/
    expire_in: 1 week