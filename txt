getArticle(category: Signal<string>, article: Signal<string>) {
    // Unificamos el proceso en un solo recurso reactivo
    const articleResource = resource({
      request: () => {
        const cat = category();
        const art = article();
        if (!cat || !art) return null;
        return { cat, art };
      },
      loader: async ({ request }) => {
        if (!request) return null;

        const { cat, art } = request;
        const metaUrl = `data/credito-zoom/articles/${cat}/${art}/metadata.json`;

        try {
          // 1. Intentar obtener la metadata del artículo
          // Si el JSON no existe y devuelve index.html, fallará automáticamente al parsear JSON.
          const metadata = await firstValueFrom(this.http.get<PostDetailModel>(metaUrl));

          if (!metadata || !metadata.contentMd) {
            throw new Error('El archivo de metadata está vacío o no contiene la ruta del contenido.');
          }

          // 2. Intentar obtener el contenido en Markdown
          const markdownText = await firstValueFrom(
            this.http.get(metadata.contentMd, { responseType: 'text' })
          );

          // SOLUCCIÓN AL SEGUNDO PROBLEMA: Validar si lo devuelto es el index.html de la SPA
          if (markdownText.trim().startsWith('<!DOCTYPE html>') || markdownText.trim().startsWith('<html')) {
            throw new Error('No se encontró el archivo Markdown (el servidor devolvió index.html).');
          }

          return { metadata, markdown: markdownText };
        } catch (err: any) {
          // Lanzamos un error descriptivo que poblará automáticamente el `.error` del recurso
          throw new Error(err.message || 'Error inesperado al cargar el artículo.');
        }
      }
    });

    // Mantenemos la firma de retorno limpia usando computeds expuestos externamente
    return {
      metadata: computed(() => articleResource.value()?.metadata),
      markdown: computed(() => articleResource.value()?.markdown),
      isLoading: articleResource.isLoading,
      error: articleResource.error,
    };
  }