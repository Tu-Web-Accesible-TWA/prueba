getArticle(category: Signal<string>, article: Signal<string>) {
  // 1. Petición para obtener los metadatos del artículo
  const metaDataResource = httpResource<PostDetailModel>(() => {
    const cat = category();
    const art = article();

    if (!cat || !art) return undefined;

    return `data/credito-zoom/articles/${cat}/${art}/metadata.json`;
  });

  // 2. Petición para obtener el contenido Markdown
  const markdownResource = httpResource.text(() => {
    const meta = metaDataResource.value();

    // Si no hay metadatos o no especifican la ruta del .md, no hace la petición
    if (!meta || !meta.contentMd) return undefined;

    return `${meta.contentMd}`;
  }, {
    // INTERCEPTOR DE ERROR: Evita que el index.html se renderice como Markdown
    transform: (text) => {
      const cleanText = text.trim();
      
      if (cleanText.startsWith('<!DOCTYPE html>') || cleanText.startsWith('<html')) {
        throw new Error('404: El archivo Markdown no existe en el servidor.');
      }
      
      return text;
    }
  });

  // 3. Retorno unificado de los recursos y estados reactivos
  return {
    metadata: metaDataResource,
    markdown: markdownResource,

    isLoading: computed(() => metaDataResource.isLoading() || markdownResource.isLoading()),
    error: computed(() => metaDataResource.error() || markdownResource.error()),
  };
}